HTSLIB_DIR=$(CURDIR)/../inst/htslib
BCFTOOLS_DIR=$(CURDIR)/../inst/bcftools

# Configure supplies platform-appropriate link inputs. Native builds use the
# installed shared HTSlib and rpath; webR links the static archive into its
# Emscripten side module.
PKG_CPPFLAGS=-I$(HTSLIB_DIR)/include -I$(BCFTOOLS_DIR)/include @EXTRA_CPPFLAGS@
PKG_LIBS=@HTSLIB_LINK_INPUT@ @EXTRA_LIBS@ @PKG_LIBS_EXTRA@ @RPATH_FLAGS@

.PHONY: all

all: $(SHLIB)

ifeq ($(shell uname -s),Darwin)
# Fix the reference to libhts to use @rpath instead of an absolute path.
	install_name_tool -change $(HTSLIB_DIR)/lib/libhts.3.dylib @rpath/libhts.3.dylib $(SHLIB)
endif
